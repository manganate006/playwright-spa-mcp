{
  "name": "playwright-spa-mcp",
  "version": "1.0.0",
  "description": "MCP server for Playwright with SPA support, persistent sessions, device emulation, and action chains",
  "main": "src/index.js",
  "bin": {
    "playwright-spa": "./bin/cli.js",
    "playwright-spa-mcp": "./src/index.js",
    "browser-screenshot": "./browser.js",
    "browser-daemon": "./browser-daemon.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node browser.js",
    "daemon": "node browser-daemon.js",
    "test": "node browser.js --url https://example.com --action screenshot"
  },
  "keywords": [
    "mcp",
    "playwright",
    "spa",
    "react",
    "vue",
    "angular",
    "browser",
    "automation",
    "screenshot",
    "testing",
    "web-scraping",
    "headless",
    "device-emulation"
  ],
  "author": "",
