  },
  "homepage": "https://github.com/manganate006/playwright-spa-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "playwright": ">=1.40.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
